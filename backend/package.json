  "name": "devschool-backend",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "DevSchool Pro — Production-grade backend API",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
