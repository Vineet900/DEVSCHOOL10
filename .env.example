# ============================================================
# DevSchool Pro — Environment Variables Template
# ============================================================
# Copy this file: cp .env.example .env
# Fill in your values. NEVER commit .env to git.
# ============================================================

# ─── Docker Compose ──────────────────────────────────────
DB_USER=devschool
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
DB_NAME=devschool_pro

# ─── Backend ─────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# Database (auto-set by docker-compose, but needed for local dev)
DATABASE_URL=postgresql://devschool:CHANGE_ME@localhost:5432/devschool_pro

# Supabase (Auth only — data in Docker PostgreSQL)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_JWT_SECRET=your-jwt-secret

# CORS
FRONTEND_URL=http://localhost:5174

# JWT
JWT_EXPIRE=30d

# AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Redis (auto-set by docker-compose)
REDIS_URL=redis://localhost:6379
